# ContentCompiler Provider Configuration

# LLM Provider selection. Options: openai, anthropic, gemini, mock
PROVIDER=openai

# Model to use. Examples: gpt-4, claude-3-opus-20240229, gemini-1.5-pro
MODEL=gpt-4

# Generation parameters
TEMPERATURE=0.7
MAX_TOKENS=2000

# API Keys (Only one is required depending on the PROVIDER selected)
# DO NOT COMMIT ACTUAL SECRETS TO THE REPOSITORY
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
GEMINI_API_KEY=YOUR_GEMINI_API_KEY
# Optional: Networking configurations
# TIMEOUT_MS=30000
# MAX_RETRIES=3
